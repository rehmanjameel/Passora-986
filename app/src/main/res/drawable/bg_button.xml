<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bottom Shadow -->
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <gradient
                android:startColor="#C54D00"
                android:endColor="#8F3300"
                android:angle="90"/>
        </shape>
    </item>

    <!-- Main Background -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">

            <corners android:radius="28dp"/>

            <gradient
                android:startColor="#FFA856"
                android:centerColor="#FF7A17"
                android:endColor="#FF5A00"
                android:angle="0"/>

            <stroke
                android:width="1dp"
                android:color="#55FFFFFF"/>

        </shape>
    </item>

    <!-- Top Gloss -->
    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="22dp">

        <shape android:shape="rectangle">
            <corners android:radius="26dp"/>

            <gradient
                android:startColor="#66FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90"/>
        </shape>

    </item>

</layer-list>