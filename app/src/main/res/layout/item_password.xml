<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/dark_grey"
    app:cardCornerRadius="24dp"
    app:cardElevation="10dp"
    app:strokeColor="@color/light_grey"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Website -->

        <TextView
            android:id="@+id/txtWebsite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Google"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chipCategory"/>

        <!-- Category -->

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCategory"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Social"
            android:textColor="@color/grey"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/light_grey"
            app:chipCornerRadius="16dp"
            app:chipStrokeWidth="0dp"
            app:layout_constraintTop_toTopOf="@id/txtWebsite"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Username -->

        <TextView
            android:id="@+id/txtUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="abdulrehman@gmail.com"
            android:textColor="@color/grey"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/txtWebsite"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Password -->

        <TextView
            android:id="@+id/txtPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="••••••••••••••"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/txtUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- View -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/light_grey"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtPassword">

            <ImageButton
                android:id="@+id/btnView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="9dp"
                android:src="@drawable/outline_visibility_lock_24"
                app:tint="@color/grey"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Copy -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCopy"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="@color/light_grey"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/cardView"
            app:layout_constraintTop_toTopOf="@id/cardView">

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="9dp"
                android:src="@drawable/outline_content_copy_24"
                app:tint="@color/grey"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Edit -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="@color/light_grey"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/cardCopy"
            app:layout_constraintTop_toTopOf="@id/cardCopy">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="9dp"
                android:src="@drawable/outline_edit_24"
                app:tint="@color/grey"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Date -->

        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="@color/grey"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/cardView"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>