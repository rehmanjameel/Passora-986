<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/pin_code"
            />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Create Security PIN"
            android:textColor="@color/textPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Create a 4-digit PIN to protect your passwords."
            android:textColor="@color/textSecondary"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- PIN Indicators -->

    <LinearLayout
        android:id="@+id/pinContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <View
            android:id="@+id/pin1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_margin="12dp"
            android:background="@drawable/bg_pin_empty" />

        <View
            android:id="@+id/pin2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_margin="12dp"
            android:background="@drawable/bg_pin_empty" />

        <View
            android:id="@+id/pin3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_margin="12dp"
            android:background="@drawable/bg_pin_empty" />

        <View
            android:id="@+id/pin4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_margin="12dp"
            android:background="@drawable/bg_pin_empty" />

    </LinearLayout>

    <!-- Number Pad -->

    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="36dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintTop_toBottomOf="@id/pinContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btn1" android:text="1" style="@style/Widget.Material3.Button.OutlinedButton"/>
        <Button android:id="@+id/btn2" android:text="2" style="@style/Widget.Material3.Button.OutlinedButton"/>
        <Button android:id="@+id/btn3" android:text="3" style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button android:id="@+id/btn4" android:text="4" style="@style/Widget.Material3.Button.OutlinedButton"/>
        <Button android:id="@+id/btn5" android:text="5" style="@style/Widget.Material3.Button.OutlinedButton"/>
        <Button android:id="@+id/btn6" android:text="6" style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button android:id="@+id/btn7" android:text="7" style="@style/Widget.Material3.Button.OutlinedButton"/>
        <Button android:id="@+id/btn8" android:text="8" style="@style/Widget.Material3.Button.OutlinedButton"/>
        <Button android:id="@+id/btn9" android:text="9" style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnDelete"
            android:text="⌫"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn0"
            android:text="0"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnDone"
            android:text="✓"
            style="@style/Widget.Material3.Button"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>